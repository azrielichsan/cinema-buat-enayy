{
  "name": "@rsbuild/core",
  "version": "2.0.15",
  "description": "The Rspack-based build tool.",
  "homepage": "https://rsbuild.rs",
  "bugs": {
    "url": "https://github.com/web-infra-dev/rsbuild/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/web-infra-dev/rsbuild",
    "directory": "packages/core"
  },
  "bin": {
    "rsbuild": "./bin/rsbuild.js"
  },
  "files": [
    "bin",
    "dist",
    "dist-types",
    "static",
    "compiled",
    "types.d.ts"
  ],
  "type": "module",
  "types": "./dist-types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-types/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./types.d.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@rspack/core": "~2.0.8",
    "@swc/helpers": "^0.5.23"
  },
  "devDependencies": {
    "@jridgewell/remapping": "^2.3.5",
    "@jridgewell/trace-mapping": "^0.3.31",
    "@rslib/core": "0.22.1",
    "@types/cors": "^2.8.19",
    "@types/node": "^24.13.2",
    "@types/on-finished": "2.3.5",
    "@types/range-parser": "^1.2.7",
    "@types/ws": "^8.18.1",
    "browserslist-load-config": "^1.0.3",
    "cac": "^7.0.0",
    "chokidar": "^5.0.0",
    "connect-next": "4.0.3",
    "core-js": "^3.49.0",
    "cors": "^2.8.6",
    "css-loader": "7.1.4",
    "deepmerge": "^4.3.1",
    "dotenv-expand": "^13.0.0",
    "html-rspack-plugin": "6.1.9",
    "http-proxy-middleware": "4.1.0",
    "jiti": "^2.7.0",
    "launch-editor-middleware": "^2.14.1",
    "memfs": "^4.57.7",
    "mrmime": "^2.0.1",
    "on-finished": "2.4.1",
    "open": "^11.0.0",
    "postcss": "^8.5.15",
    "postcss-load-config": "6.0.1",
    "postcss-loader": "8.2.1",
    "prebundle": "1.6.5",
    "range-parser": "^1.2.1",
    "reduce-configs": "^2.0.1",
    "rslog": "^2.1.3",
    "rspack-chain": "^2.1.0",
    "rspack-manifest-plugin": "5.2.2",
    "rspack-merge": "1.0.1",
    "sirv": "^3.0.2",
    "stacktrace-parser": "^0.1.11",
    "style-loader": "^4.0.0",
    "tinyglobby": "^0.2.17",
    "typescript": "^6.0.3",
    "ws": "^8.21.0"
  },
  "peerDependencies": {
    "core-js": ">= 3.0.0"
  },
  "peerDependenciesMeta": {
    "core-js": {
      "optional": true
    }
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "rslib",
    "dev": "rslib -w",
    "prebundle": "prebundle"
  }
}